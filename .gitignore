# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
venv/
.venv/
env/

# Earth Engine / GCP service account credentials — NEVER commit these
service-account-key.json
*-service-account*.json
.streamlit/secrets.toml

# Local env files
.env
.env.local

# Generated / cached data (rebuildable by running the pipeline — keep out of
# version control so the repo doesn't silently ship stale derived data)
data/baselines/*.json
!data/baselines/.gitkeep
data/case_files/*/before.tif
data/case_files/*/after.tif
data/anomaly_cache.json
data/dashboard.json

# Generated satellite imagery (regenerated by generate_dashboard_data.py)
app_frontend/imagery/

# Pipeline run logs
*.log
pipeline*.log

# NOTE: data/segments/*.geojson and data/case_files/*/metadata.json, writeup.md
# and evidence_card.json are intentionally NOT ignored — they're source data
# and outputs meant to be versioned/reviewed (transparency signal, spec Section 6).

# OS / editor
.DS_Store
.vscode/
.idea/
