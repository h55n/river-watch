# Copy this file to .env (and never commit the real .env) for local dev,
# or set these as actual environment variables / Streamlit secrets in
# whatever you deploy to. See README.md "Getting API access" section for
# where to obtain each of these — all are free.

# --- Google Earth Engine (required for the pipeline) ---
# GCP project ID registered for Earth Engine access (free, non-commercial use).
EE_PROJECT=your-gcp-project-id

# Only needed if using a service account instead of `earthengine authenticate`
# (recommended for Streamlit Community Cloud / CI, since there's no browser
# to complete an interactive auth flow there).
EE_SERVICE_ACCOUNT=your-service-account-email@your-project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- NASA FIRMS (required only for the Signal 3 fire/thermal overlay) ---
FIRMS_API_KEY=your-firms-map-key

# --- Global Forest Watch (no key required for public Data API endpoints) ---
# Nothing to set here today; gfw_client.py uses GFW's public query endpoint.
# If GFW later requires a key for the endpoints you use, add GFW_API_KEY here.
