# Streamlit secrets template.
#
# For Streamlit Community Cloud: copy these keys into your app's
# "Secrets" settings in the dashboard (Settings -> Secrets) — do NOT commit
# a real .streamlit/secrets.toml to git (it's already in .gitignore).
#
# For local dev: copy this file to .streamlit/secrets.toml and fill in real
# values, OR just use a .env file / exported env vars (see .env.example) --
# pipeline/gee_auth.py and integrations/firms_client.py read from
# os.environ, and Streamlit automatically exposes st.secrets entries as
# environment variables is NOT automatic -- if you only set st.secrets, add
# a one-line shim at the top of app/streamlit_app.py:
#   import os, streamlit as st
#   for k, v in st.secrets.items(): os.environ.setdefault(k, str(v))

EE_PROJECT = "your-gcp-project-id"
EE_SERVICE_ACCOUNT = "your-service-account-email@your-project.iam.gserviceaccount.com"
# Paste the FULL contents of your service account JSON key here as a string,
# or use Streamlit Cloud's native secrets-as-file support if available, then
# write it to a temp path at app startup and point GOOGLE_APPLICATION_CREDENTIALS at it.
GOOGLE_APPLICATION_CREDENTIALS_JSON = """
{ ... paste service account key JSON here ... }
"""

FIRMS_API_KEY = "your-firms-map-key"
